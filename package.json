{
	"name": "tokyotech-portal-autofill",
	"description": "A browser extension to autofill matrix codes on the Tokyo Tech portal.",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"build": "tsc --noEmit && wxt build",
		"zip": "tsc --noEmit && wxt zip",
		"check": "tsc --noEmit && biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@dotenvx/dotenvx": "^1.61.0",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"conventional-recommended-bump": "^11.2.0",
		"typescript": "^5.9.3",
		"web-ext": "^10.1.0",
		"wxt": "^0.20.20"
	}
}
